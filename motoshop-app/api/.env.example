# Configuración de ejemplo para la API MotoShop.
# Copiar a .env y rellenar valores reales.

# ─── MySQL motoshop2024 (lectura, api_read) ─────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=motoshop2024
MYSQL_USER=api_read
MYSQL_PASSWORD=

# ─── MySQL app_writer (escritura a app_*, F5+) ─────────────
MYSQL_APP_WRITER_USER=app_writer
MYSQL_APP_WRITER_PASSWORD=

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# ─── Usuarios ────────────────────────────────────────────────
USERS_FILE_PATH=users.yaml

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ─── Backend de datos (V1.5+) ──────────────────────────────────
# V1.5: el read path usa DuckDB. Databricks está DEPRECATED para lectura.
DATA_BACKEND=duckdb                # duckdb (prod V1.5+) | databricks (legacy)
DUCKDB_PATH=/tmp/motoshop_gold.duckdb

# ─── R2 (Cloudflare) — bootstrap y refresh del archivo DuckDB ──
R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=motoshop-gold

# ─── Telegram — destino explícito por tenant ───────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID_MOTOSHOP=
TELEGRAM_CHAT_ID_MASVITAL=

# ─── Databricks — DEPRECATED V1.5 (read backend reemplazado) ──
# Solo necesario para build_duckdb_from_export (seed interino sin MySQL)
# DATABRICKS_HOST=https://dbc-e311b140-dab8.cloud.databricks.com
# DATABRICKS_TOKEN=
# DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/43bc044eaef4cca4

# ─── Entorno ─────────────────────────────────────────────────
ENV=dev
