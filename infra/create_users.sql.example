-- ============================================================
-- Creacion de usuarios MySQL read-only para MotoShop
-- Ejecutar como root en el MySQL local:
--   mysql -u root < infra\create_users.sql.example
--
-- NOTA: MySQL 5.0 no soporta IF NOT EXISTS ni DROP IF EXISTS.
-- Si ya existen, se omite el error.
-- ============================================================

-- Usuario para el script de dump/ingesta (Track A)
CREATE USER 'analytics'@'localhost'
  IDENTIFIED BY '123450';

GRANT SELECT ON `motoshop2024`.* TO 'analytics'@'localhost';

-- Usuario para la API FastAPI (Track T)
CREATE USER 'api_read'@'localhost'
  IDENTIFIED BY '123450';

GRANT SELECT ON `motoshop2024`.* TO 'api_read'@'localhost';

-- Usuario personal de Javier
CREATE USER 'javier'@'localhost'
  IDENTIFIED BY '123450';

GRANT SELECT ON `motoshop2024`.* TO 'javier'@'localhost';

FLUSH PRIVILEGES;

-- Mostrar usuarios creados
SELECT User, Host FROM mysql.User WHERE User IN ('analytics', 'api_read', 'javier');
