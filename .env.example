# Plantilla de variables de entorno del proyecto MotoShop.
# Copiar a .env y rellenar valores reales. Nunca commitear .env.
# Cada track tiene además su propio .env.example dentro de su carpeta.

# ─── MySQL motoshop2024 (origen, solo lectura) ─────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=motoshop2024
# Usuario analytics (Track A) y api_read (Track T) se crean en F0.
# Mientras tanto puede usarse root sin contraseña en LOCAL del PC.
MYSQL_USER=
MYSQL_PASSWORD=

# ─── Backups ───────────────────────────────────────────────
# Ruta destino para infra/backup_mysql.sh. Debe estar FUERA del repo.
MOTOSHOP_BACKUP_DIR=~/Backups/motoshop

# ─── App Writer (F5+, escritura a tablas app_*) ───────────
# Usuario MySQL con INSERT/SELECT sobre app_* y SELECT sobre sgHermes.
# Ver infra/migrations/F5-003-grant_app_writer.sql
MYSQL_APP_WRITER_PASSWORD=

# ─── JWT Secret (F5+) ────────────────────────────────────
# Secreto para firmar tokens JWT. Usar una cadena larga y aleatoria.
JWT_SECRET=

# ─── MySQL root (scripts de infraestructura) ─────────────
# Solo para scripts que necesitan mysqladmin -u root (check_health, start_api, etc.)
# NO se usa para la aplicación.
MYSQL_ROOT_PASSWORD=

# ─── Databricks (Track A) ──────────────────────────────────
DATABRICKS_HOST=https://dbc-e311b140-dab8.cloud.databricks.com
DATABRICKS_TOKEN=
DATABRICKS_WAREHOUSE_ID=
DATABRICKS_CATALOG=motoshop
# Volume UC de aterrizaje de los dumps locales (ver infra/setup_uc_volume.md)
DATABRICKS_VOLUME_PATH=/Volumes/motoshop/bronze/_landing

# ─── Cloudflare Tunnel (Track T, F0) ───────────────────────
CLOUDFLARE_TUNNEL_TOKEN=
