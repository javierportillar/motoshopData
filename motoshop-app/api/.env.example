# Configuración de ejemplo para la API MotoShop.
# Copiar a .env y rellenar valores reales.

# ─── MySQL motoshop2024 (lectura, api_read) ─────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=motoshop2024
MYSQL_USER=api_read
MYSQL_PASSWORD=

# ─── MySQL app_writer (escritura a app_*, F5+) ─────────────
MYSQL_APP_WRITER_USER=app_writer
MYSQL_APP_WRITER_PASSWORD=

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# ─── Usuarios ────────────────────────────────────────────────
USERS_FILE_PATH=users.yaml

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ─── Backend de datos (V1.5+) ──────────────────────────────────
DATA_BACKEND=databricks       # duckdb | databricks (default: databricks)
DUCKDB_PATH=/tmp/motoshop_gold.duckdb

# ─── Entorno ─────────────────────────────────────────────────
ENV=dev
