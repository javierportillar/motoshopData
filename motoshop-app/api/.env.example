# Variables de entorno de la API. Copiar a .env y rellenar.
# pydantic-settings cargará este archivo automáticamente.

# Entorno: dev | staging | prod
ENV=dev

# Conexión MySQL motoshop2024 (usuario api_read, read-only)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=motoshop2024
MYSQL_USER=api_read
MYSQL_PASSWORD=

# CORS — orígenes permitidos para la PWA (coma-separados)
CORS_ORIGINS=http://localhost:3000

# JWT (se activa en Fase 1 — dejar vacío en F0)
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7
